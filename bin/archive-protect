#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat >&2 <<EOF
Usage: $(basename "$0") <directory|file> [redundancy%]

Creates a SHA-256 manifest and PAR2 recovery set for archival.
Output goes to <name>.parset/ alongside the target.

  directory|file  Read-only archive directory or single file to protect
  redundancy%     PAR2 redundancy level 1-100 (default: 10)

To verify later (from anywhere):
  <name>.parset/verify.sh
EOF
    exit 1
}

die() { echo "error: $*" >&2; exit 1; }

_fmt_dur() {
    local s=$(( $1 ))
    (( s < 60 ))   && { printf '%ds' $s; return; }
    (( s < 3600 )) && { printf '%dm %02ds' $((s/60)) $((s%60)); return; }
    printf '%dh %02dm' $((s/3600)) $(( (s%3600)/60 ))
}

# Filter par2's \r-based progress lines and inject ETA. Reads from stdin.
_par2_filter() {
    python3 -u -c "
import sys, re, time
start = time.time()
buf = ''
def fmt(s):
    s = max(0, int(s))
    if s < 60:   return f'{s}s'
    if s < 3600: return f'{s//60}m {s%60:02d}s'
    return f'{s//3600}h {(s%3600)//60:02d}m'
while True:
    b = sys.stdin.buffer.read(1)
    if not b: break
    c = b.decode('utf-8', errors='replace')
    if c == '\r':
        m = re.search(r'(\d+\.?\d*)%', buf)
        if m:
            pct = float(m.group(1))
            elapsed = time.time() - start
            eta_str = f' | ETA {fmt(elapsed*(100-pct)/pct)}' if pct > 0.5 else ''
            sys.stdout.write(f'\r{buf.strip()}{eta_str}   ')
            sys.stdout.flush()
        else:
            print(buf)
        buf = ''
    elif c == '\n':
        print(buf)
        buf = ''
    else:
        buf += c
if buf:
    print(buf)
"
}

[[ $# -lt 1 || "${1:-}" == -h || "${1:-}" == --help ]] && usage

_TSTART=$SECONDS
TARGET="$1"
REDUNDANCY="${2:-10}"

[[ -e "$TARGET" ]] || die "'$TARGET' does not exist"
[[ -f "$TARGET" || -d "$TARGET" ]] || die "'$TARGET' is not a file or directory"
[[ "$REDUNDANCY" =~ ^[1-9][0-9]*$ ]] || die "redundancy must be a positive integer, got: $REDUNDANCY"
[[ "$REDUNDANCY" -le 100 ]] || die "redundancy must be <= 100, got: $REDUNDANCY"

command -v par2 >/dev/null 2>&1 \
    || die "'par2' not found — install with: brew install par2"

if command -v sha256sum >/dev/null 2>&1; then
    SHA256_CMD=(sha256sum)
elif command -v shasum >/dev/null 2>&1; then
    SHA256_CMD=(shasum -a 256)
else
    die "neither sha256sum nor shasum found"
fi

# Resolve to physical absolute path, then derive PARENT and BASENAME.
if [[ -f "$TARGET" ]]; then
    TARGET="$(cd "$(dirname "$TARGET")" && pwd -P)/$(basename "$TARGET")"
    PARENT="$(dirname "$TARGET")"
    BASENAME="$(basename "$TARGET")"
    declare -a FILES=("$BASENAME")
else
    TARGET="$(cd "$TARGET" && pwd -P)"
    PARENT="$(dirname "$TARGET")"
    BASENAME="$(basename "$TARGET")"
    declare -a FILES=()
    while IFS= read -r -d '' f; do
        f="${f#./}"
        FILES+=("${BASENAME}/${f}")
    done < <(cd "$TARGET" && find . -type f -print0 | sort -z)
fi

OUTDIR="${PARENT}/${BASENAME}.parset"
FILE_COUNT=${#FILES[@]}

# Compute total source bytes to derive a sane block size (~512 KB target).
# Setting block_count = file_count causes par2's bisection to pick block_size ≈
# largest file, padding every small file to that size and ballooning recovery data.
# Using total_bytes / 512KB gives block_size ≈ 512KB regardless of file count mix.
TOTAL_BYTES=$(cd "$PARENT" && printf '%s\0' "${FILES[@]}" | xargs -0 stat -f '%z' | awk '{s+=$1} END {print int(s)}')

# Block count strategy differs by mode:
# - Directory: target ~512 KB blocks to avoid padding waste. With many small files,
#   large block_size causes par2 to pad each file to the block boundary — a 1 MB
#   file in a 52 MB block wastes 51 MB of Reed-Solomon work. Cap at 32768.
# - Single file: padding is at most one block regardless of size, so use par2's
#   default of 2000 blocks (8.5 MB blocks for 17 GB). 16× less RS work than 32768.
if [[ -d "$TARGET" ]]; then
    TARGET_BLOCK_SIZE=$(( 512 * 1024 ))
    COMPUTED_COUNT=$(( (TOTAL_BYTES + TARGET_BLOCK_SIZE - 1) / TARGET_BLOCK_SIZE ))
    BLOCK_COUNT=$(( COMPUTED_COUNT > FILE_COUNT ? COMPUTED_COUNT : FILE_COUNT ))
    BLOCK_COUNT=$(( BLOCK_COUNT > 32768 ? 32768 : BLOCK_COUNT ))
else
    BLOCK_COUNT=""  # use par2 default (2000)
fi

# Use all available logical CPUs; par2cmdline-turbo detects them but may not
# default to using all, depending on how OpenMP support was compiled in.
PAR2_THREADS=$(sysctl -n hw.logicalcpu 2>/dev/null || nproc 2>/dev/null || echo 4)

echo "Target:     $TARGET"
echo "Output:     $OUTDIR"
echo "Redundancy: ${REDUNDANCY}%"
echo "Files:      ${FILE_COUNT}"
echo "Bytes:      ${TOTAL_BYTES}"
echo "Blocks:     ${BLOCK_COUNT:-2000 (par2 default)}"

if [[ -d "$OUTDIR" ]]; then
    die "'$OUTDIR' already exists — delete it first: rm -rf \"${OUTDIR}\""
fi
mkdir -p "$OUTDIR"

MANIFEST="${OUTDIR}/${BASENAME}.sha256"

# --- PAR2 recovery set (slow — do this first) ---
echo
echo "==> Creating PAR2 recovery set (${REDUNDANCY}% redundancy)..."
# -B must be an absolute path at create time; -B . is only expanded at verify time.
# Directory mode uses -R BASENAME (not -R alone) — passing BASENAME explicitly
# constrains recursion to that directory only; -R without an explicit target
# recurses the entire PARENT. This also sidesteps ARG_MAX (~1 MB on macOS) which
# is hit at ~18k files if all paths are passed as arguments.
# Single-file mode passes the one file explicitly; ARG_MAX is not a concern.
_T=$SECONDS
if [[ -d "$TARGET" ]]; then
    (cd "$PARENT" && par2create -r"${REDUNDANCY}" -b"${BLOCK_COUNT}" -t"${PAR2_THREADS}" -T4 -B "${PARENT}" -R "${BASENAME}.parset/${BASENAME}.par2" "${BASENAME}") 2>&1 | _par2_filter
else
    (cd "$PARENT" && par2create -r"${REDUNDANCY}" ${BLOCK_COUNT:+-b"${BLOCK_COUNT}"} -t"${PAR2_THREADS}" -T4 -B "${PARENT}" "${BASENAME}.parset/${BASENAME}.par2" "${FILES[@]}") 2>&1 | _par2_filter
fi
echo
echo "    done in $(_fmt_dur $(( SECONDS - _T )))"

# --- SHA-256 manifest (fast — after par2 so interrupting par2 doesn't waste time here) ---
echo
echo "==> Creating SHA-256 manifest..."
# printf|xargs batches filenames to stay under ARG_MAX — safe for 100k+ files.
_T=$SECONDS
(cd "$PARENT" && printf '%s\0' "${FILES[@]}" | xargs -0 "${SHA256_CMD[@]}") > "$MANIFEST"
echo "    ${FILE_COUNT} files checksummed in $(_fmt_dur $(( SECONDS - _T )))"
echo "    Written: $MANIFEST"

# --- verify.sh ---
# Written into .parset/ so the pair is self-contained after relocation.
# -B . at verify/repair time DOES expand to CWD, so we cd to $PARENT first.
cat > "${OUTDIR}/verify.sh" <<'VERIFY_EOF'
#!/usr/bin/env bash
set -euo pipefail
PARSET_DIR="$(cd "$(dirname "$0")" && pwd -P)"
PARENT="$(dirname "$PARSET_DIR")"
NAME="${PARSET_DIR##*/}"; NAME="${NAME%.parset}"

if command -v sha256sum >/dev/null 2>&1; then SHA256_CHECK="sha256sum --check"
else SHA256_CHECK="shasum -a 256 --check"; fi

echo "==> Verifying SHA-256 checksums..."
(cd "$PARENT" && $SHA256_CHECK "${PARSET_DIR}/${NAME}.sha256")

echo "==> Verifying PAR2 integrity..."
(cd "$PARENT" && par2 verify -B . "${PARSET_DIR}/${NAME}.par2")
VERIFY_EOF
chmod +x "${OUTDIR}/verify.sh"

# --- repair.sh ---
cat > "${OUTDIR}/repair.sh" <<'REPAIR_EOF'
#!/usr/bin/env bash
set -euo pipefail
PARSET_DIR="$(cd "$(dirname "$0")" && pwd -P)"
PARENT="$(dirname "$PARSET_DIR")"
NAME="${PARSET_DIR##*/}"; NAME="${NAME%.parset}"

echo "==> Repairing with PAR2..."
(cd "$PARENT" && par2 repair -B . "${PARSET_DIR}/${NAME}.par2")
REPAIR_EOF
chmod +x "${OUTDIR}/repair.sh"

# Mark .parset for Finder: add a "parset" tag and set the bundle bit so it
# sorts/looks distinct from data directories (gray dot, appears as a package).
_mark_parset_for_finder() {
    local dir="$1"
    # Finder tag "parset" with gray color (\n1 suffix encodes gray in macOS tags).
    local _tags_hex
    _tags_hex=$(python3 -c "
import plistlib, binascii
data = plistlib.dumps(['parset\n1'], fmt=plistlib.FMT_BINARY)
print(binascii.hexlify(data).decode())
") && xattr -wx com.apple.metadata:_kMDItemUserTags "$_tags_hex" "$dir" 2>/dev/null || true
    # Bundle bit (kHasBundle = 0x2000) in FinderInfo frFlags (bytes 8–9, big-endian).
    # 32 zero bytes with 0x2000 at offset 8.
    xattr -wx com.apple.FinderInfo \
        "0000000000000000200000000000000000000000000000000000000000000000" \
        "$dir" 2>/dev/null || true
}
_mark_parset_for_finder "$OUTDIR"

echo
echo "==> Done in $(_fmt_dur $(( SECONDS - _TSTART )))."
ls -lh "$OUTDIR"
