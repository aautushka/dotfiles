#!/usr/bin/env bash
# End-to-end test for archive-protect:
#   1. Protect the test-archive fixture
#   2. Relocate both dirs to /tmp
#   3. Corrupt a file
#   4. verify.sh detects corruption
#   5. repair.sh restores the file
#   6. verify.sh passes clean

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ARCHIVE_PROTECT="${SCRIPT_DIR}/archive-protect"
FIXTURE="${SCRIPT_DIR}/../test-archive"
FIXTURE="$(cd "$FIXTURE" && pwd)"

WORK_DIR="$(mktemp -d /tmp/archive-protect-test.XXXXXX)"
trap 'rm -rf "$WORK_DIR"' EXIT

pass() { echo "  [PASS] $*"; }
fail() { echo "  [FAIL] $*" >&2; exit 1; }
step() { echo; echo "--- $* ---"; }

# ── 1. copy fixture into work dir (simulates a real archive you own) ──────────
step "Setup: copy fixture to $WORK_DIR"
cp -r "$FIXTURE" "$WORK_DIR/test-archive"
ARCHIVE="${WORK_DIR}/test-archive"
echo "  archive: $ARCHIVE"
ls -lR "$ARCHIVE"

# ── 2. protect ────────────────────────────────────────────────────────────────
step "Protect archive (50% redundancy)"
"$ARCHIVE_PROTECT" "$ARCHIVE" 50
PARSET="${WORK_DIR}/test-archive.parset"
[[ -d "$PARSET" ]] || fail "parset dir not created"
[[ -f "${PARSET}/test-archive.sha256" ]] || fail "manifest not created"
[[ -f "${PARSET}/test-archive.par2" ]]   || fail "par2 index not created"
[[ -f "${PARSET}/verify.sh" ]]           || fail "verify.sh not created"
[[ -f "${PARSET}/repair.sh" ]]           || fail "repair.sh not created"
pass "parset created"

# ── 3. initial verify ─────────────────────────────────────────────────────────
step "Initial verify (should be clean)"
"${PARSET}/verify.sh" || fail "initial verify failed"
pass "initial verify OK"

# ── 4. relocate ───────────────────────────────────────────────────────────────
step "Relocate both dirs to a new location"
NEW_HOME="$(mktemp -d /tmp/archive-protect-relocated.XXXXXX)"
# new home is cleaned up via WORK_DIR trap only if we nest — use separate trap
trap 'rm -rf "$WORK_DIR" "$NEW_HOME"' EXIT

mv "$ARCHIVE" "$NEW_HOME/test-archive"
mv "$PARSET"  "$NEW_HOME/test-archive.parset"
ARCHIVE="${NEW_HOME}/test-archive"
PARSET="${NEW_HOME}/test-archive.parset"
echo "  relocated to: $NEW_HOME"
pass "relocation done"

# ── 5. verify after relocation (should still be clean) ────────────────────────
step "Verify after relocation"
"${PARSET}/verify.sh" || fail "post-relocation verify failed"
pass "post-relocation verify OK"

# ── 6. corrupt a file ─────────────────────────────────────────────────────────
step "Corrupt test-archive/notes.txt"
CORRUPT_FILE="${ARCHIVE}/notes.txt"
ORIGINAL_SIZE=$(wc -c < "$CORRUPT_FILE")
# overwrite 256 bytes in the middle of the file
OFFSET=$(( ORIGINAL_SIZE / 3 ))
python3 -c "
f = open('${CORRUPT_FILE}', 'r+b')
f.seek(${OFFSET})
f.write(b'\\x00' * 256)
f.close()
"
echo "  wrote 256 null bytes at offset ${OFFSET} of ${CORRUPT_FILE}"
pass "file corrupted"

# ── 7. verify detects corruption ──────────────────────────────────────────────
step "Verify should detect corruption"
if "${PARSET}/verify.sh" 2>/dev/null; then
    fail "verify should have failed but passed"
fi
pass "corruption detected"

# ── 8. repair ─────────────────────────────────────────────────────────────────
step "Repair with PAR2"
"${PARSET}/repair.sh" || fail "repair failed"
pass "repair completed"

# ── 9. verify restored file matches original ──────────────────────────────────
step "Verify restored file matches original"
ORIGINAL_HASH=$(sha256sum "$FIXTURE/notes.txt" 2>/dev/null || shasum -a 256 "$FIXTURE/notes.txt")
ORIGINAL_HASH="${ORIGINAL_HASH%% *}"
RESTORED_HASH=$(sha256sum "$CORRUPT_FILE" 2>/dev/null || shasum -a 256 "$CORRUPT_FILE")
RESTORED_HASH="${RESTORED_HASH%% *}"
[[ "$ORIGINAL_HASH" == "$RESTORED_HASH" ]] \
    || fail "restored file hash mismatch: expected $ORIGINAL_HASH, got $RESTORED_HASH"
pass "restored file matches original"

# ── 10. final verify ──────────────────────────────────────────────────────────
step "Final verify (should be clean)"
"${PARSET}/verify.sh" || fail "final verify failed"
pass "final verify OK"

echo
echo "All tests passed."
