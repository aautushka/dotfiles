#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat >&2 <<EOF
Usage: $(basename "$0") <file|directory>

Remove the immutable flag and restore user write permissions, recursively
for directories. Reverses the effect of archive-lock.
Shows progress for large directories. Removes the red Finder tag.

On failure, automatically rolls back to fully locked state.

To re-lock: archive-lock <file|directory>
EOF
    exit 1
}

die() { echo "error: $*" >&2; exit 1; }

[[ $# -eq 1 && "${1:-}" != -h && "${1:-}" != --help ]] || usage

if [[ -d "$1" ]]; then
    TARGET="$(cd "$1" && pwd -P)" || die "cannot resolve '$1'"
elif [[ -f "$1" ]]; then
    TARGET="$(cd "$(dirname "$1")" && pwd -P)/$(basename "$1")" || die "cannot resolve '$1'"
else
    die "'$1' is not a file or directory"
fi

# ---------------------------------------------------------------------------
# Finder tag helpers — cosmetic, non-fatal
# ---------------------------------------------------------------------------

_tag_add_locked() {
    python3 - "$TARGET" <<'PY' 2>/dev/null || true
import sys, plistlib, binascii, subprocess
path = sys.argv[1]
try:
    r = subprocess.run(['xattr', '-px', 'com.apple.metadata:_kMDItemUserTags', path],
                       capture_output=True, text=True, check=True)
    tags = plistlib.loads(bytes.fromhex(r.stdout.strip().replace(' ', '')))
except Exception:
    tags = []
tag = 'locked\n6'
if tag not in tags:
    tags.append(tag)
data = plistlib.dumps(tags, fmt=plistlib.FMT_BINARY)
subprocess.run(['xattr', '-wx', 'com.apple.metadata:_kMDItemUserTags',
                binascii.hexlify(data).decode(), path], check=True)
PY
}

_tag_remove_locked() {
    python3 - "$TARGET" <<'PY' 2>/dev/null || true
import sys, plistlib, binascii, subprocess
path = sys.argv[1]
try:
    r = subprocess.run(['xattr', '-px', 'com.apple.metadata:_kMDItemUserTags', path],
                       capture_output=True, text=True, check=True)
    tags = plistlib.loads(bytes.fromhex(r.stdout.strip().replace(' ', '')))
except Exception:
    tags = []
tags = [t for t in tags if t != 'locked\n6']
data = plistlib.dumps(tags, fmt=plistlib.FMT_BINARY)
subprocess.run(['xattr', '-wx', 'com.apple.metadata:_kMDItemUserTags',
                binascii.hexlify(data).decode(), path], check=True)
PY
}

# ---------------------------------------------------------------------------
# Rollback: on any failure, fully re-lock and restore tag
# ---------------------------------------------------------------------------

_rollback() {
    local rc=$?
    printf '\n' >&2
    printf '\033[1;31merror: unlock failed — rolling back to locked state...\033[0m\n' >&2
    local rb_ok=1
    chmod   -R a-w  "$TARGET" 2>&1 || rb_ok=0
    chflags -R uchg "$TARGET" 2>&1 || rb_ok=0
    _tag_add_locked
    if [[ $rb_ok -eq 1 ]]; then
        printf '\033[1;32mRolled back: '\''%s'\'' is fully locked.\033[0m\n' "$TARGET" >&2
    else
        printf '\033[1;31mCRITICAL: rollback incomplete — '\''%s'\'' may be in a mixed state.\033[0m\n' "$TARGET" >&2
        printf '\033[1;31mRun manually: chmod -R a-w "%s" && chflags -R uchg "%s"\033[0m\n' "$TARGET" "$TARGET" >&2
    fi
    exit $rc
}
trap _rollback ERR

printf '\033[1mUnlocking: %s\033[0m\n' "$TARGET"

if [[ -d "$TARGET" ]]; then
    # -------------------------------------------------------------------------
    # Directory: unlock root first (so we can write to it), then contents.
    # chflags nouchg must precede chmod — uchg blocks chmod on locked files.
    # Tag is removed last, after $TARGET is writable.
    # -------------------------------------------------------------------------
    chflags nouchg "$TARGET"
    chmod   u+w    "$TARGET"

    printf '  counting files...'
    total=$(find "$TARGET" -mindepth 1 | wc -l | tr -d ' ')
    [[ $total -gt 0 ]] || total=1
    printf '\r  %d files found\n' "$total"

    count=0
    while IFS= read -r -d '' f; do
        chflags nouchg "$f"
        chmod   u+w    "$f"
        (( ++count ))
        if (( count % 500 == 0 )); then
            printf '\r  %3d%%  (%d / %d files)' "$(( count * 100 / total ))" "$count" "$total"
        fi
    done < <(find "$TARGET" -mindepth 1 -print0)
    printf '\r  100%%  (%d / %d files)\n' "$count" "$total"

    _tag_remove_locked
else
    # -------------------------------------------------------------------------
    # Single file: chflags before chmod (uchg blocks chmod).
    # -------------------------------------------------------------------------
    chflags nouchg "$TARGET"
    chmod   u+w    "$TARGET"
    _tag_remove_locked
fi

trap - ERR
printf '\033[1;32mUnlocked: %s\033[0m\n' "$TARGET"
printf '\033[1;33mTo re-lock: archive-lock "%s"\033[0m\n' "$TARGET"
